---

<div
  class="anim-fade-in flex flex-col md:flex-row gap-6 mb-6 items-center md:items-start"
>
  <!-- Avatar -->
  <div class="relative flex-shrink-0">
    <div
      class="absolute inset-0 rounded-full bg-blue-400/30 dark:bg-blue-400/20 blur-xl scale-125 animate-pulse-glow"
      aria-hidden="true"
    >
    </div>
    <img
      class="avatar-ring relative rounded-full shadow-2xl w-40 h-40 ring-2 ring-offset-2 transition-transform duration-300 hover:scale-110 ring-offset-gray-50 dark:ring-offset-[#0b2a35]"
      src="../public/projects/me.png"
      alt={personalImageAlt}
    />
  </div>

  <!-- Texte -->
  <div class="text-center md:text-left md:flex-1">
    <a
      href="#contact"
      class="flex items-center justify-center md:justify-start transition md:hover:scale-105 mb-4"
    >
      <Badge><SparklesIcon class="size-3" /> Disponible pour une embauche</Badge
      >
    </a>
    <h1
      class="anim-fade-in anim-delay-1 text-4xl font-bold tracking-tight text-gray-800 sm:text-5xl dark:text-white"
    >
      Salut, je suis <span class="gradient-name">TSIMANARY</span>
    </h1>
    <p class="mt-6 text-xl text-gray-800 dark:text-gray-300 text-pretty">
      Développeur Full Stack passionné, je conçois et réalise des applications
      web et mobile performantes et évolutives avec
      <strong class="text-blue-500 dark:text-green-400"
        >Laravel, React, Flutter et Flask</strong
      >. À l'aise avec les environnements modernes de déploiement, je maîtrise
      <strong class="text-blue-500 dark:text-green-400"
        >Docker, Kubernetes et Google Cloud</strong
      >
      pour livrer des solutions robustes et scalables.
    </p>
    <!-- Navigation sociale ICI — dans le même bloc que le texte -->
    <nav
      class="anim-fade-in anim-delay-3 flex flex-wrap justify-center md:justify-start gap-4 mt-8"
      aria-label="Réseaux sociaux et contact"
    >
      <SocialPill href="#contact">
        <MailIcon class="size-4" />
        Contactez-moi
      </SocialPill>
      <SocialPill
        href="https://www.linkedin.com/in/tsimanary-alliance-484059307/"
      >
        <LinkedInIcon class="size-4" />
        LinkedIn
      </SocialPill>
      <SocialPill href="https://github.com/dashboard">
        <GitHubIcon class="size-4" />
        GitHub
      </SocialPill>
      <SocialPill href="/Tsimanary-CV.pdf" download="Tsimanary-CV.pdf">
        <svg
          class="size-4"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"
          ></path>
        </svg>
        Télécharger mon CV
      </SocialPill>
    </nav>
  </div>
</div>

<!-- Bande tech animée -->
<div class="tech-strip-wrapper" aria-label="Technologies maîtrisées">
  <div class="tech-strip">
    {
      [...techs, ...techs].map((tech) => (
        <div
          class="tech-pill"
          style={
            "--tc-dark:" +
            tech.color +
            "; --tc-light:" +
            tech.colorLight +
            "; --bg-dark:" +
            tech.bgDark +
            "; --bg-light:" +
            tech.bgLight +
            ";"
          }
        >
          <span class="tech-pill-icon" set:html={tech.svg} />
          <span class="tech-pill-name">{tech.name}</span>
        </div>
      ))
    }
  </div>
</div>

<style>
  /* === Avatar === */
  html.dark .avatar-glow {
    background: rgba(92, 246, 92, 0.3);
  }
  .avatar-glow {
    background: rgba(59, 130, 246, 0.25);
  }
  html.dark .avatar-ring {
    --tw-ring-color: rgba(92, 246, 143, 0.55);
  }
  .avatar-ring {
    --tw-ring-color: rgba(59, 130, 246, 0.5);
  }

  /* === Nom dégradé === */
  html.dark .gradient-name {
    background: linear-gradient(90deg, #49ed3a, #b5fdbb, #8bfaf4);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .gradient-name {
    background: linear-gradient(90deg, #2563eb, #60a5fa, #3b82f6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* === Bande tech === */
  .tech-strip-wrapper {
    position: relative;
    width: 100%;
    margin-top: 2.5rem;
    overflow: hidden;
    padding: 12px 0;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
  }

  .tech-strip {
    display: flex;
    gap: 0.75rem;
    width: max-content;
    animation: scroll-left 40s linear infinite;
    padding: 4px 0;
  }
  .tech-strip:hover {
    animation-play-state: paused;
  }

  @keyframes scroll-left {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* === Pill === */
  .tech-pill {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 1rem 0.45rem 0.6rem;
    border-radius: 10px;
    border: 1px solid transparent;
    white-space: nowrap;
    cursor: default;
    transition:
      transform 0.2s,
      box-shadow 0.2s,
      border-color 0.2s;
    flex-shrink: 0;
    /* Mode sombre par défaut */
    background: var(--bg-dark);
    border-color: color-mix(in srgb, var(--tc-dark) 30%, transparent);
  }

  /* Mode clair */
  html:not(.dark) .tech-pill {
    background: var(--bg-light);
    border-color: color-mix(in srgb, var(--tc-light) 25%, transparent);
  }

  /* Hover sombre */
  .tech-pill:hover {
    transform: translateY(-3px) scale(1.05);
    border-color: var(--tc-dark);
    box-shadow: 0 8px 24px -6px
      color-mix(in srgb, var(--tc-dark) 50%, transparent);
  }

  /* Hover clair */
  html:not(.dark) .tech-pill:hover {
    border-color: var(--tc-light);
    box-shadow: 0 8px 24px -6px
      color-mix(in srgb, var(--tc-light) 40%, transparent);
  }

  /* Icône */
  .tech-pill-icon {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .tech-pill-icon svg {
    width: 24px;
    height: 24px;
  }

  /* Texte */
  .tech-pill-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--tc-dark);
  }
  html:not(.dark) .tech-pill-name {
    color: var(--tc-light);
  }
</style>
