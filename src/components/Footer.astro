---
const currentYear = new Date().getFullYear();
---

<footer
  class="opacity-80 m-4 min-[375px]:pl-4 md:pl-0 mt-16 w-full mx-auto container lg:max-w-4xl md:max-w-2xl mb-10 flex justify-center relative"
>
  <hr class="footer-divider" />

  <!-- Contenu footer -->
  <div class="footer-content">
    <p class="footer-copy">
      &copy; {currentYear}
      <a href="/" class="footer-name">TSIMANARY Andriniaina Bonheur</a>. Tous
      droits réservés.
    </p>
    <p class="footer-sub">Développé avec Astro & Tailwind CSS</p>
  </div>

  <!-- Boutons flottants -->
  <div class="fixed bottom-6 right-6 flex flex-col gap-3">
    <!-- Bouton WhatsApp -->
    <a
      href="https://wa.me/0344510268"
      target="_blank"
      class="w-12 h-12 flex items-center justify-center rounded-full shadow-lg
             text-white bg-green-500 dark:bg-green-500 transition duration-300 hover:scale-110 hover:shadow-[0_0_15px_rgba(79,223,138,0.7)]"
      aria-label="WhatsApp"
    >
      <!-- Icône WhatsApp -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="currentColor"
        viewBox="0 0 16 16"
        class="w-6 h-6"
      >
        <path
          d="M13.601 2.326A7.953 7.953 0 0 0 8.002 0C3.582 0 .002 3.58.002 8c0 1.41.37 2.79 1.07 4.01L0 16l4.09-1.07A7.96 7.96 0 0 0 8.002 16c4.42 0 8-3.58 8-8 0-2.13-.83-4.14-2.401-5.674zM8.002 14.5a6.48 6.48 0 0 1-3.47-1.01l-.25-.15-2.43.64.65-2.37-.16-.25a6.48 6.48 0 0 1-1.01-3.46c0-3.58 2.92-6.5 6.5-6.5 1.74 0 3.38.68 4.61 1.91a6.48 6.48 0 0 1 1.89 4.59c0 3.58-2.92 6.5-6.5 6.5z"
        ></path>
      </svg>
    </a>

    <!-- Bouton scroll top -->
    <button
      onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
      class="w-12 h-12 flex items-center justify-center rounded-full shadow-lg
             text-white bg-blue-500 dark:bg-blue-500 transition duration-300
         hover:scale-110 hover:bg-blue-600
         hover:shadow-[0_0_15px_rgba(59,130,246,0.7)]"
      aria-label="Remonter"
    >
      <!-- Icône flèche -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="currentColor"
        viewBox="0 0 16 16"
        class="w-6 h-6"
      >
        <path
          d="M8 3.293l4.646 4.647-.707.707L8 4.707l-3.939 3.94-.707-.707L8 3.293z"
        ></path>
      </svg>
    </button>
  </div>
</footer>
<style>
  /* === Contenu === */
  .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    padding-bottom: 2.5rem;
    text-align: center;
  }

  .footer-copy {
    font-size: 14px;
    margin: 0;
    color: #475569;
  }
  html.dark .footer-copy {
    color: #94a3b8;
  }

  .footer-name {
    font-weight: 700;
    text-decoration: none;
    color: #3b82f6;
    transition: opacity 0.2s;
  }
  html.dark .footer-name {
    color: #4ade80;
  }
  .footer-name:hover {
    opacity: 0.75;
    text-decoration: underline;
  }

  .footer-sub {
    font-size: 12px;
    margin: 0;
    color: #94a3b8;
  }
  html.dark .footer-sub {
    color: #475569;
  }

  /* === Boutons flottants === */
  .float-btn {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    color: #ffffff;
    transition:
      transform 0.25s,
      box-shadow 0.25s;
  }
  .float-btn:hover {
    transform: scale(1.12);
  }

  /* WhatsApp */
  .whatsapp-btn {
    background: #22c55e;
    text-decoration: none;
    box-shadow: 0 4px 14px rgba(34, 197, 94, 0.4);
  }
  .whatsapp-btn:hover {
    box-shadow: 0 0 20px rgba(34, 197, 94, 0.65);
  }

  /* Scroll top */
  .scroll-btn {
    background: #3b82f6;
    box-shadow: 0 4px 14px rgba(59, 130, 246, 0.4);
  }
  html.dark .scroll-btn {
    background: #4ade80;
    color: #052e16;
    box-shadow: 0 4px 14px rgba(74, 222, 128, 0.35);
  }
  .scroll-btn:hover {
    box-shadow: 0 0 20px rgba(59, 130, 246, 0.65);
  }
  html.dark .scroll-btn:hover {
    box-shadow: 0 0 20px rgba(74, 222, 128, 0.55);
  }
  /* === Séparateur === */
  .footer-divider {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    border: none;
    border-top: 1px solid rgba(59, 130, 246, 0.2);
    margin: 0;
  }
  html.dark .footer-divider {
    border-top-color: rgba(74, 222, 128, 0.15);
  }
</style>
