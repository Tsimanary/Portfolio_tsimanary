---
import "@fontsource-variable/onest";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { ViewTransitions } from "astro:transitions";

interface Props {
  title: string;
  description: string;
}

const { description, title } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="darkreader-lock" />
    <ViewTransitions />

    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"
      is:inline></script>
    <script
      src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.net.min.js"
      is:inline></script>
  </head>

  <body class="relative text-black dark:text-white">
    <!-- Canvas Vanta plein écran fixe -->
    <div id="vanta-bg" class="fixed inset-0 z-[-2]"></div>

    <!-- Surcouche opacity pour lisibilité — mise à jour par JS selon le mode -->
    <div
      id="vanta-overlay"
      class="fixed inset-0 pointer-events-none"
      style="z-index: -1; background: rgba(8, 12, 28, 0.55);"
      aria-hidden="true"
    >
    </div>

    <Header />
    <slot />
    <Footer />

    <style is:global>
      :root {
        color-scheme: light dark;
      }

      html {
        font-family: "Onest Variable", system-ui, sans-serif;
        scroll-behavior: smooth;
      }

      body {
        color: rgba(17, 17, 17, 0.9);
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        overscroll-behavior: none;
      }

      @media (prefers-color-scheme: dark) {
        body {
          color: rgba(255, 255, 255, 0.9);
        }
      }

      #vanta-bg {
        width: 100%;
        height: 100%;
      }

      @keyframes blur {
        to {
          backdrop-filter: blur(20px);
          border-width: 1px;
          border-color: rgba(0, 0, 0);
          padding: 0.25rem 0.75rem;
          display: flex;
          flex-direction: row;
          align-items: center;
          background-color: rgb(229, 229, 229);
          border-radius: 9999px;
        }
      }

      @media (prefers-color-scheme: dark) {
        @keyframes blur {
          from {
            border: 0px;
          }
          to {
            box-shadow:
              0px 5px 50px -5px rgba(0, 0, 0, 0.1),
              0px 0px 0 1px rgba(0, 0, 0, 0.3);
            background: rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(20px);
            border-width: 1px;
            border-color: rgba(0, 0, 0);
            padding: 0.25rem 0.75rem;
            display: flex;
            flex-direction: row;
            align-items: center;
            border-radius: 9999px;
          }
        }
      }

      @keyframes fade-in-up {
        from {
          opacity: 0;
          translate: 0 20px;
        }
        to {
          opacity: 1;
          translate: 0 0;
        }
      }

      .anim-fade-in {
        animation: fade-in-up 0.65s cubic-bezier(0.22, 1, 0.36, 1) both;
      }
      .anim-delay-1 {
        animation-delay: 120ms;
      }
      .anim-delay-2 {
        animation-delay: 260ms;
      }
      .anim-delay-3 {
        animation-delay: 400ms;
      }
      .anim-delay-4 {
        animation-delay: 540ms;
      }

      .gradient-name {
        background: linear-gradient(135deg, #3b82f6 10%, #2563eb 90%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        color: transparent;
      }

      html.dark .gradient-name {
        background: linear-gradient(135deg, #3fff82 10%, #00c864 90%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      @supports (animation-timeline: view()) {
        [data-section] {
          animation: fade-in-up 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
          animation-timeline: view();
          animation-range: entry 0% entry 18%;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .anim-fade-in,
        [data-section] {
          animation: none !important;
          opacity: 1 !important;
          translate: none !important;
        }
      }

      @keyframes pulse-glow {
        0%,
        100% {
          transform: scale(1.2);
          opacity: 0.6;
        }
        50% {
          transform: scale(1.35);
          opacity: 0.9;
        }
      }
      .animate-pulse-glow {
        animation: pulse-glow 3s ease-in-out infinite;
      }

      .social-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        border-radius: 9999px;
        font-weight: 500;
        transition: all 0.2s;
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(8px);
        color: #1e293b;
        border: 1px solid rgba(0, 0, 0, 0.08);
      }
      html.dark .social-pill {
        background: rgba(255, 255, 255, 0.07);
        color: #e2f0ef;
        border-color: rgba(255, 255, 255, 0.1);
      }
      .social-pill:hover {
        background: #3b82f6;
        color: white;
        border-color: transparent;
      }
      html.dark .social-pill:hover {
        background: #3fff82;
        color: #0b1a14;
        border-color: transparent;
      }
    </style>

    <script is:inline>
      (function () {
        const DARK_CONFIG = {
          color: 0x3fff82,
          backgroundColor: 0x151b3c,
        };
        const LIGHT_CONFIG = {
          color: 0x3cefa,
          backgroundColor: 0xebebeb,
        };

        let vantaEffect = null;

        function isDark() {
          return document.documentElement.classList.contains("dark");
        }

        /* === Surcouche opacity === */
        function updateOverlay() {
          const overlay = document.getElementById("vanta-overlay");
          if (!overlay) return;
          if (isDark()) {
            // Sombre : voile noir → atténue le réseau vert
            overlay.style.background = "rgba(8, 12, 28, 0.7)";
          } else {
            // Clair : voile blanc → atténue le réseau bleu 
            overlay.style.background = "rgba(240, 245, 255, 0.7)";  
          }
        }

        function initVanta() {
          if (vantaEffect) {
            vantaEffect.destroy();
            vantaEffect = null;
          }

          if (typeof VANTA === "undefined" || typeof THREE === "undefined") {
            setTimeout(initVanta, 100);
            return;
          }

          const cfg = isDark() ? DARK_CONFIG : LIGHT_CONFIG;

          vantaEffect = VANTA.NET({
            el: "#vanta-bg",
            THREE: THREE,
            mouseControls: true,
            touchControls: true,
            gyroControls: false,
            minHeight: 200.0,
            minWidth: 200.0,
            scale: 1.0,
            scaleMobile: 1.0,
            color: cfg.color,
            backgroundColor: cfg.backgroundColor,
            points: 10.0,
            maxDistance: 20.0,
            spacing: 15.0,
            showDots: true,
          });

          // Mettre à jour la surcouche après chaque init
          updateOverlay();
        }

        document.addEventListener("DOMContentLoaded", initVanta);
        document.addEventListener("astro:page-load", initVanta);
        document.addEventListener("astro:after-swap", initVanta);

        const observer = new MutationObserver(function (mutations) {
          mutations.forEach(function (mutation) {
            if (
              mutation.type === "attributes" &&
              mutation.attributeName === "class"
            ) {
              initVanta();
            }
          });
        });

        observer.observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["class"],
        });
      })();
    </script>
  </body>
</html>
