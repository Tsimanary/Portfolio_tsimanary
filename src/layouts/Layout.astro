---
import "@fontsource-variable/onest";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { ViewTransitions } from "astro:transitions";

interface Props {
  title: string;
  description: string;
}

const { description, title } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="darkreader-lock" />
    <ViewTransitions />

    <!-- Vanta.js : Three.js requis en premier -->
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"
      is:inline
    ></script>
    <script
      src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.net.min.js"
      is:inline
    ></script>
  </head>

  <body class="relative text-black dark:text-white">
    <!-- Canvas Vanta plein écran fixe -->
    <div id="vanta-bg" class="fixed inset-0 z-[-2]"></div>

    <Header />
    <slot />
    <Footer />

    <style is:global>
      :root {
        color-scheme: light dark;
      }

      html {
        font-family: "Onest Variable", system-ui, sans-serif;
        scroll-behavior: smooth;
      }

      body {
        color: rgba(17, 17, 17, 0.9);
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        overscroll-behavior: none;
      }

      @media (prefers-color-scheme: dark) {
        body {
          color: rgba(255, 255, 255, 0.9);
        }
      }

      /* Vanta canvas toujours derrière tout */
      #vanta-bg {
        width: 100%;
        height: 100%;
      }

      /* Légère surcouche pour lisibilité du contenu */
      #vanta-bg::after {
        content: "";
        position: absolute;
        inset: 0;
        background: rgba(255, 255, 255, 0.08);
        pointer-events: none;
      }

      html.dark #vanta-bg::after {
        background: rgba(0, 0, 0, 0.15);
      }

      @keyframes blur {
        to {
          backdrop-filter: blur(20px);
          border-width: 1px;
          border-color: rgba(0, 0, 0);
          padding: 0.25rem 0.75rem;
          display: flex;
          flex-direction: row;
          align-items: center;
          background-color: rgb(229, 229, 229);
          border-radius: 9999px;
        }
      }

      @media (prefers-color-scheme: dark) {
        @keyframes blur {
          from { border: 0px; }
          to {
            box-shadow: 0px 5px 50px -5px rgba(0,0,0,0.1), 0px 0px 0 1px rgba(0,0,0,0.3);
            background: rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(20px);
            border-width: 1px;
            border-color: rgba(0, 0, 0);
            padding: 0.25rem 0.75rem;
            display: flex;
            flex-direction: row;
            align-items: center;
            border-radius: 9999px;
          }
        }
      }

      @keyframes fade-in-up {
        from { opacity: 0; translate: 0 20px; }
        to   { opacity: 1; translate: 0 0; }
      }

      .anim-fade-in  { animation: fade-in-up 0.65s cubic-bezier(0.22, 1, 0.36, 1) both; }
      .anim-delay-1  { animation-delay: 120ms; }
      .anim-delay-2  { animation-delay: 260ms; }
      .anim-delay-3  { animation-delay: 400ms; }
      .anim-delay-4  { animation-delay: 540ms; }

      .gradient-name {
        background: linear-gradient(135deg, #3b82f6 10%, #2563eb 90%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        color: transparent;
      }

      html.dark .gradient-name {
        background: linear-gradient(135deg, #3fff82 10%, #00c864 90%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      @supports (animation-timeline: view()) {
        [data-section] {
          animation: fade-in-up 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
          animation-timeline: view();
          animation-range: entry 0% entry 18%;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .anim-fade-in, [data-section] {
          animation: none !important;
          opacity: 1 !important;
          translate: none !important;
        }
      }

      @keyframes pulse-glow {
        0%, 100% { transform: scale(1.2);  opacity: 0.6; }
        50%       { transform: scale(1.35); opacity: 0.9; }
      }
      .animate-pulse-glow { animation: pulse-glow 3s ease-in-out infinite; }

      .social-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        border-radius: 9999px;
        font-weight: 500;
        transition: all 0.2s;
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(8px);
        color: #1e293b;
        border: 1px solid rgba(0,0,0,0.08);
      }
      html.dark .social-pill {
        background: rgba(255,255,255,0.07);
        color: #e2f0ef;
        border-color: rgba(255,255,255,0.1);
      }
      .social-pill:hover {
        background: #3b82f6;
        color: white;
        border-color: transparent;
      }
      html.dark .social-pill:hover {
        background: #3fff82;
        color: #0b1a14;
        border-color: transparent;
      }
    </style>

    <!-- Script Vanta : init + écoute changement de thème -->
    <script is:inline>
      (function () {
        // Couleurs selon le mode
        const DARK_CONFIG = {
          color: 0x3fff82,       // vert clair (lignes/points)
          backgroundColor: 0x151b3c, // bleu nuit foncé
        };
        const LIGHT_CONFIG = {
          color: 0x3cefa,        // bleu cyan
          backgroundColor: 0xebebeb, // gris très clair
        };

        let vantaEffect = null;

        function isDark() {
          return document.documentElement.classList.contains("dark");
        }

        function initVanta() {
          if (vantaEffect) {
            vantaEffect.destroy();
            vantaEffect = null;
          }

          // Attendre que VANTA et THREE soient disponibles
          if (typeof VANTA === "undefined" || typeof THREE === "undefined") {
            setTimeout(initVanta, 100);
            return;
          }

          const cfg = isDark() ? DARK_CONFIG : LIGHT_CONFIG;

          vantaEffect = VANTA.NET({
            el: "#vanta-bg",
            THREE: THREE,
            mouseControls: true,
            touchControls: true,
            gyroControls: false,
            minHeight: 200.0,
            minWidth: 200.0,
            scale: 1.0,
            scaleMobile: 1.0,
            color: cfg.color,
            backgroundColor: cfg.backgroundColor,
            points: 10.0,
            maxDistance: 20.0,
            spacing: 15.0,
            showDots: true,
          });
        }

        // Init au chargement
        document.addEventListener("DOMContentLoaded", initVanta);

        // Ré-init à chaque transition de page Astro
        document.addEventListener("astro:page-load", initVanta);
        document.addEventListener("astro:after-swap", initVanta);

        // Observer les changements de classe dark sur <html>
        const observer = new MutationObserver(function (mutations) {
          mutations.forEach(function (mutation) {
            if (
              mutation.type === "attributes" &&
              mutation.attributeName === "class"
            ) {
              initVanta();
            }
          });
        });

        observer.observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["class"],
        });
      })();
    </script>
  </body>
</html>